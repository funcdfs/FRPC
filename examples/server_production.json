{
  "server": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8080,
    "max_connections": 50000,
    "idle_timeout_seconds": 300,
    "worker_threads": 8
  },
  "connection_pool": {
    "min_connections": 10,
    "max_connections": 200,
    "idle_timeout_seconds": 240,
    "cleanup_interval_seconds": 60
  },
  "health_check": {
    "interval_seconds": 15,
    "timeout_seconds": 5,
    "failure_threshold": 3,
    "success_threshold": 2
  },
  "logging": {
    "level": "INFO",
    "file": "/var/log/frpc/server.log",
    "console": false,
    "max_file_size_mb": 100,
    "max_files": 10
  }
}
